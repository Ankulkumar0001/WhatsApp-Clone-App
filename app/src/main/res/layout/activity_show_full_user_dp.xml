<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Show_Full_User_DP_Activity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/show_fulldp_materialToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/black"
        app:title="User_Name"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentLeft="true"
        app:navigationIcon="@drawable/backwhite"
        app:popupTheme="@style/MyPopupMenu"
        app:titleTextColor="@color/white" />

    <ImageView
        android:id="@+id/full_size_dp"
        android:layout_width="match_parent"
        android:layout_centerInParent="true"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:layout_height="400dp"
        android:src="@drawable/userplaceeholder"
        android:scaleType="fitXY"/>

</RelativeLayout>