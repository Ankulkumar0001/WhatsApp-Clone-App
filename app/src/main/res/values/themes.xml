<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.FireBasePracticeApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->

        <item name="colorPrimary">@color/green</item>
        <item name="android:colorPrimary">@color/green</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/green</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorAccent">@color/green</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/green</item>
        <item name="colorOnBackground">@color/green</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.FireBasePracticeApp" parent="Base.Theme.FireBasePracticeApp" />

    <style name="MyPopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:textColor">@color/black</item>
        <item name="popupMenuBackground">@color/white</item>
    </style>

    <style name="MyPopupMenu2" parent="Widget.Material3.PopupMenu">
        <item name="android:colorBackground">@color/white</item> <item name="android:textColor">@color/black</item>
    </style>
</resources>